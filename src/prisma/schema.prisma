generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Users & Authentication
// =============================================================================

enum UserRole {
  ADMIN
  MODERATOR
  PLAYER
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(PLAYER)
  steamId      String?  @unique @map("steam_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions    Session[]
  auditLogs   AuditLog[]   @relation("AuditActor")
  storeOrders StoreOrder[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("sessions")
}

// =============================================================================
// Server Profiles
// =============================================================================

model ServerProfile {
  id         String  @id @default(cuid())
  name       String  @unique
  isActive   Boolean @default(false) @map("is_active")
  servername String  @default("servertest")
  steamBuild String  @default("public") @map("steam_build")

  // Network
  gamePort   Int @default(16261) @map("game_port")
  directPort Int @default(16262) @map("direct_port")
  rconPort   Int @default(27015) @map("rcon_port")
  rconPassword String @default("") @map("rcon_password")

  // Game settings
  mapName    String  @default("Muldraugh, KY") @map("map_name")
  maxPlayers Int     @default(16) @map("max_players")
  pvp        Boolean @default(true)
  difficulty String  @default("Normal")

  // Additional settings stored as JSON
  serverIniOverrides   Json?     @map("server_ini_overrides")
  sandboxVarsOverrides Json?     @map("sandbox_vars_overrides")
  automationStudioConfig Json?   @map("automation_studio_config")
  automationState      Json?     @map("automation_state")
  lastGameState        Json?     @map("last_game_state")
  lastTelemetryAt      DateTime? @map("last_telemetry_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mods               Mod[]
  modRuntimeReports  ModRuntimeReport[]
  backups            Backup[]
  jobs               Job[]
  players            ServerPlayer[]
  snapshots          PlayerSnapshot[]
  telemetryEvents    PlayerTelemetryEvent[]
  telemetryListeners TelemetryListener[]
  workflows          WorkflowDefinition[]
  workflowRuns       WorkflowRun[]
  actionRules        ActionRule[]
  automationActionExecutions AutomationActionExecution[]
  rewardRules        RewardRule[]
  rewardGrants       RewardGrant[]
  xpGrants           XpGrant[]
  storeCategories    StoreCategory[]
  storeProducts      StoreProduct[]
  storeBundles       StoreBundle[]
  storeOrders        StoreOrder[]

  @@map("server_profiles")
}

// =============================================================================
// Game Settings
// =============================================================================

model GameSetting {
  id       String @id @default(cuid())
  category String // "server_ini" or "sandbox_vars"
  key      String
  value    String
  type     String @default("string") // string, number, boolean

  @@unique([category, key])
  @@map("game_settings")
}

// =============================================================================
// Mods
// =============================================================================

model Mod {
  id          String  @id @default(cuid())
  profileId   String  @map("profile_id")
  workshopId  String  @map("workshop_id")
  modName     String  @map("mod_name")
  displayName String? @map("display_name")
  previewUrl  String? @map("preview_url")
  order       Int     @default(0)
  isEnabled   Boolean @default(true) @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile ServerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, workshopId])
  @@map("mods")
}

model ModRuntimeReport {
  id                String   @id @default(cuid())
  profileId         String   @map("profile_id")
  serverName        String   @map("server_name")
  reason            String?
  activeModIds      Json     @map("active_mod_ids")
  activeWorkshopIds Json?    @map("active_workshop_ids")
  reportedAt        DateTime @default(now()) @map("reported_at")

  profile ServerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, reportedAt])
  @@map("mod_runtime_reports")
}

// =============================================================================
// Backups
// =============================================================================

model Backup {
  id          String   @id @default(cuid())
  profileId   String   @map("profile_id")
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  sizeBytes   BigInt   @map("size_bytes")
  gameVersion String?  @map("game_version")
  createdAt   DateTime @default(now()) @map("created_at")

  profile ServerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("backups")
}

// =============================================================================
// Jobs (Background Tasks)
// =============================================================================

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum JobType {
  BACKUP
  RESTORE
  RESTART
  UPDATE
  WIPE
  STOP
}

model Job {
  id         String    @id @default(cuid())
  type       JobType
  status     JobStatus @default(PENDING)
  profileId  String?   @map("profile_id")
  payload    Json?
  result     Json?
  error      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")

  profile ServerProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@map("jobs")
}

// =============================================================================
// Audit Logging
// =============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?  @map("actor_id")
  action    String
  target    String?
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// Whitelist
// =============================================================================

model WhitelistEntry {
  id        String   @id @default(cuid())
  steamId   String   @unique @map("steam_id")
  username  String?
  addedBy   String?  @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("whitelist")
}

// =============================================================================
// Scheduled Tasks
// =============================================================================

model ScheduledTask {
  id        String  @id @default(cuid())
  name      String
  type      String // "backup", "restart", "message"
  cron      String // Cron expression
  payload   Json?
  isEnabled Boolean @default(true) @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("scheduled_tasks")
}

// =============================================================================
// Telemetry & Rewards
// =============================================================================

enum TelemetryEventType {
  SESSION_STARTED
  SESSION_ENDED
  PLAYER_DIED
  ZOMBIE_KILL
  PVP_KILL
  SKILL_LEVEL_UP
  ITEM_FOUND
  BUILD_ACTION
}

enum RewardTriggerType {
  ZOMBIE_KILL
  PVP_KILL
  SKILL_LEVEL_UP
  ITEM_FOUND
  BUILD_ACTION
}

enum TriggerSourceKind {
  EVENT
  WORKFLOW
}

enum WorkflowRunStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

model ServerPlayer {
  id              String    @id @default(cuid())
  profileId       String    @map("profile_id")
  username        String
  steamId         String?   @map("steam_id")
  displayName     String?   @map("display_name")
  isOnline        Boolean   @default(false) @map("is_online")
  isDead          Boolean   @default(false) @map("is_dead")
  isGhost         Boolean   @default(false) @map("is_ghost")
  x               Float?
  y               Float?
  z               Int?
  zombieKills     Int       @default(0) @map("zombie_kills")
  playerKills     Int       @default(0) @map("player_kills")
  hoursSurvived   Float     @default(0) @map("hours_survived")
  profession      String?
  skills          Json?
  inventory       Json?
  automationState Json?     @map("automation_state")
  firstSeenAt     DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime  @default(now()) @map("last_seen_at")
  lastTelemetryAt DateTime? @map("last_telemetry_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  profile         ServerProfile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  snapshots       PlayerSnapshot[]
  telemetryEvents PlayerTelemetryEvent[]
  workflowRuns    WorkflowRun[]
  xpBalance       PlayerXpBalance?
  xpCategories    PlayerXpCategoryBalance[]
  xpGrants        XpGrant[]
  wallet          PlayerWallet?
  rewardGrants    RewardGrant[]
  automationActionExecutions AutomationActionExecution[]
  storeOrders     StoreOrder[]

  @@unique([profileId, username])
  @@index([profileId, isOnline])
  @@map("server_players")
}

model PlayerSnapshot {
  id            String   @id @default(cuid())
  profileId     String   @map("profile_id")
  playerId      String   @map("player_id")
  capturedAt    DateTime @default(now()) @map("captured_at")
  isOnline      Boolean  @default(true) @map("is_online")
  isDead        Boolean  @default(false) @map("is_dead")
  isGhost       Boolean  @default(false) @map("is_ghost")
  x             Float?
  y             Float?
  z             Int?
  zombieKills   Int      @default(0) @map("zombie_kills")
  playerKills   Int      @default(0) @map("player_kills")
  hoursSurvived Float    @default(0) @map("hours_survived")
  profession    String?
  skills        Json?
  inventory     Json?
  raw           Json?

  profile ServerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  player  ServerPlayer  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([profileId, capturedAt])
  @@index([playerId, capturedAt])
  @@map("player_snapshots")
}

model PlayerTelemetryEvent {
  id         String              @id @default(cuid())
  profileId  String              @map("profile_id")
  playerId   String?             @map("player_id")
  type       TelemetryEventType?
  eventKey   String              @map("event_key")
  quantity   Int                 @default(1)
  occurredAt DateTime            @map("occurred_at")
  source     String              @default("lua_mod")
  metadata   Json?
  createdAt  DateTime            @default(now()) @map("created_at")

  profile  ServerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  player   ServerPlayer? @relation(fields: [playerId], references: [id], onDelete: SetNull)
  grants   RewardGrant[]
  xpGrants XpGrant[]
  automationActionExecutions AutomationActionExecution[]

  @@index([profileId, eventKey, occurredAt])
  @@index([profileId, type, occurredAt])
  @@index([playerId, occurredAt])
  @@map("player_telemetry_events")
}

model TelemetryListener {
  id         String   @id @default(cuid())
  profileId  String   @map("profile_id")
  adapterKey String   @map("adapter_key")
  name       String
  eventKey   String?  @map("event_key")
  isEnabled  Boolean  @default(true) @map("is_enabled")
  config     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  profile ServerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, adapterKey])
  @@index([profileId, isEnabled])
  @@map("telemetry_listeners")
}

model WorkflowDefinition {
  id        String   @id @default(cuid())
  profileId String   @map("profile_id")
  key       String
  name      String
  isEnabled Boolean  @default(true) @map("is_enabled")
  config    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile ServerProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  steps   WorkflowStep[]
  runs    WorkflowRun[]

  @@unique([profileId, key])
  @@index([profileId, isEnabled])
  @@map("workflow_definitions")
}

model WorkflowStep {
  id            String   @id @default(cuid())
  workflowId    String   @map("workflow_id")
  stepOrder     Int      @map("step_order")
  eventKey      String   @map("event_key")
  withinSeconds Int?     @map("within_seconds")
  matchConfig   Json?    @map("match_config")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stepOrder])
  @@index([workflowId, eventKey])
  @@map("workflow_steps")
}

model WorkflowRun {
  id            String            @id @default(cuid())
  workflowId    String            @map("workflow_id")
  profileId     String            @map("profile_id")
  playerId      String?           @map("player_id")
  status        WorkflowRunStatus @default(ACTIVE)
  currentStep   Int               @default(0) @map("current_step")
  context       Json?
  startedAt     DateTime          @default(now()) @map("started_at")
  lastMatchedAt DateTime?         @map("last_matched_at")
  expiresAt     DateTime?         @map("expires_at")
  completedAt   DateTime?         @map("completed_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  profile  ServerProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  player   ServerPlayer?      @relation(fields: [playerId], references: [id], onDelete: SetNull)
  xpGrants XpGrant[]
  automationActionExecutions AutomationActionExecution[]

  @@index([workflowId, status])
  @@index([profileId, playerId, status])
  @@map("workflow_runs")
}

model ActionRule {
  id               String            @id @default(cuid())
  profileId        String            @map("profile_id")
  name             String
  triggerKind      TriggerSourceKind @map("trigger_kind")
  triggerKey       String            @map("trigger_key")
  isEnabled        Boolean           @default(true) @map("is_enabled")
  moneyAmount      Int               @default(0) @map("money_amount")
  xpAmount         Int               @default(0) @map("xp_amount")
  xpCategory       String?           @map("xp_category")
  xpCategoryAmount Int               @default(0) @map("xp_category_amount")
  config           Json?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  profile      ServerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rewardGrants RewardGrant[]
  xpGrants     XpGrant[]
  automationActionExecutions AutomationActionExecution[]

  @@index([profileId, triggerKind, triggerKey, isEnabled])
  @@map("action_rules")
}

model RewardRule {
  id            String            @id @default(cuid())
  profileId     String            @map("profile_id")
  name          String
  triggerType   RewardTriggerType @map("trigger_type")
  rewardAmount  Int               @default(0) @map("reward_amount")
  isEnabled     Boolean           @default(true) @map("is_enabled")
  triggerConfig Json?             @map("trigger_config")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  profile ServerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  grants  RewardGrant[]

  @@index([profileId, triggerType, isEnabled])
  @@map("reward_rules")
}

model PlayerWallet {
  id          String   @id @default(cuid())
  playerId    String   @unique @map("player_id")
  balance     Int      @default(0)
  totalEarned Int      @default(0) @map("total_earned")
  totalSpent  Int      @default(0) @map("total_spent")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  player ServerPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_wallets")
}

model PlayerXpBalance {
  id        String   @id @default(cuid())
  playerId  String   @unique @map("player_id")
  totalXp   Int      @default(0) @map("total_xp")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  player ServerPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_xp_balances")
}

model PlayerXpCategoryBalance {
  id        String   @id @default(cuid())
  playerId  String   @map("player_id")
  category  String
  totalXp   Int      @default(0) @map("total_xp")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  player ServerPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, category])
  @@index([category])
  @@map("player_xp_category_balances")
}

model RewardGrant {
  id            String   @id @default(cuid())
  profileId     String   @map("profile_id")
  playerId      String   @map("player_id")
  ruleId        String?  @map("rule_id")
  actionRuleId  String?  @map("action_rule_id")
  sourceEventId String?  @map("source_event_id")
  uniqueKey     String?  @unique @map("unique_key")
  amount        Int
  reason        String
  metadata      Json?
  grantedAt     DateTime @default(now()) @map("granted_at")

  profile     ServerProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  player      ServerPlayer          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  rule        RewardRule?           @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  actionRule  ActionRule?           @relation(fields: [actionRuleId], references: [id], onDelete: SetNull)
  sourceEvent PlayerTelemetryEvent? @relation(fields: [sourceEventId], references: [id], onDelete: SetNull)

  @@index([profileId, grantedAt])
  @@index([playerId, grantedAt])
  @@map("reward_grants")
}

model XpGrant {
  id            String   @id @default(cuid())
  profileId     String   @map("profile_id")
  playerId      String   @map("player_id")
  actionRuleId  String?  @map("action_rule_id")
  sourceEventId String?  @map("source_event_id")
  workflowRunId String?  @map("workflow_run_id")
  uniqueKey     String?  @unique @map("unique_key")
  category      String?
  amount        Int
  reason        String
  metadata      Json?
  grantedAt     DateTime @default(now()) @map("granted_at")

  profile     ServerProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  player      ServerPlayer          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  actionRule  ActionRule?           @relation(fields: [actionRuleId], references: [id], onDelete: SetNull)
  sourceEvent PlayerTelemetryEvent? @relation(fields: [sourceEventId], references: [id], onDelete: SetNull)
  workflowRun WorkflowRun?          @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([profileId, grantedAt])
  @@index([playerId, grantedAt])
  @@index([playerId, category, grantedAt])
  @@map("xp_grants")
}

model AutomationActionExecution {
  id            String   @id @default(cuid())
  profileId     String   @map("profile_id")
  playerId      String   @map("player_id")
  actionRuleId  String   @map("action_rule_id")
  sourceEventId String?  @map("source_event_id")
  workflowRunId String?  @map("workflow_run_id")
  effectType    String   @map("effect_type")
  uniqueKey     String   @unique @map("unique_key")
  status        String   @default("PENDING")
  reason        String
  metadata      Json?
  error         String?
  queuedAt      DateTime @default(now()) @map("queued_at")
  executedAt    DateTime? @map("executed_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  profile     ServerProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  player      ServerPlayer          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  actionRule  ActionRule            @relation(fields: [actionRuleId], references: [id], onDelete: Cascade)
  sourceEvent PlayerTelemetryEvent? @relation(fields: [sourceEventId], references: [id], onDelete: SetNull)
  workflowRun WorkflowRun?          @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([profileId, status, queuedAt])
  @@index([playerId, status, queuedAt])
  @@map("automation_action_executions")
}

// =============================================================================
// Storefront
// =============================================================================

enum StoreOptionDisplayType {
  TEXT
  COLOR
}

enum StoreOrderStatus {
  PROCESSING
  DELIVERED
  FAILED
  CANCELLED
}

enum StoreOrderLineKind {
  VARIANT
  BUNDLE
}

model StoreCategory {
  id              String   @id @default(cuid())
  profileId       String   @map("profile_id")
  name            String
  slug            String
  description     String?
  heroTitle       String?  @map("hero_title")
  heroDescription String?  @map("hero_description")
  accentColor     String?  @map("accent_color")
  icon            String?
  sortOrder       Int      @default(0) @map("sort_order")
  isFeatured      Boolean  @default(false) @map("is_featured")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  profile      ServerProfile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  productLinks StoreProductCategory[]

  @@unique([profileId, slug])
  @@unique([profileId, name])
  @@index([profileId, isActive, sortOrder])
  @@map("store_categories")
}

model StoreProduct {
  id             String   @id @default(cuid())
  profileId      String   @map("profile_id")
  name           String
  slug           String
  summary        String?
  description    String?
  overview       String?
  featureBullets Json?    @map("feature_bullets")
  specs          Json?
  badge          String?
  accentColor    String?  @map("accent_color")
  isFeatured     Boolean  @default(false) @map("is_featured")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  profile             ServerProfile                @relation(fields: [profileId], references: [id], onDelete: Cascade)
  categories          StoreProductCategory[]
  optionGroups        StoreProductOptionGroup[]
  variants            StoreProductVariant[]
  orderLines          StoreOrderLine[]
  recommendationsFrom StoreProductRecommendation[] @relation("StoreProductRecommendationSource")
  recommendationsTo   StoreProductRecommendation[] @relation("StoreProductRecommendationTarget")

  @@unique([profileId, slug])
  @@index([profileId, isActive, isFeatured, sortOrder])
  @@map("store_products")
}

model StoreProductCategory {
  productId  String @map("product_id")
  categoryId String @map("category_id")
  sortOrder  Int    @default(0) @map("sort_order")

  product  StoreProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category StoreCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, sortOrder])
  @@map("store_product_categories")
}

model StoreProductOptionGroup {
  id          String                 @id @default(cuid())
  productId   String                 @map("product_id")
  name        String
  slug        String
  displayType StoreOptionDisplayType @default(TEXT) @map("display_type")
  sortOrder   Int                    @default(0) @map("sort_order")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  product StoreProduct              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  StoreProductOptionValue[]

  @@unique([productId, slug])
  @@index([productId, sortOrder])
  @@map("store_product_option_groups")
}

model StoreProductOptionValue {
  id            String   @id @default(cuid())
  optionGroupId String   @map("option_group_id")
  label         String
  slug          String
  description   String?
  colorHex      String?  @map("color_hex")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  optionGroup       StoreProductOptionGroup          @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  variantSelections StoreProductVariantOptionValue[]

  @@unique([optionGroupId, slug])
  @@index([optionGroupId, sortOrder])
  @@map("store_product_option_values")
}

model StoreProductVariant {
  id             String   @id @default(cuid())
  productId      String   @map("product_id")
  name           String
  sku            String   @unique
  itemCode       String   @map("item_code")
  gameName       String?  @map("game_name")
  gameCategory   String?  @map("game_category")
  price          Int
  compareAtPrice Int?     @map("compare_at_price")
  quantity       Int      @default(1)
  stock          Int?
  weight         Decimal? @db.Decimal(10, 2)
  badge          String?
  imageUrl       String?  @map("image_url")
  isDefault      Boolean  @default(false) @map("is_default")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  product     StoreProduct                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  selections  StoreProductVariantOptionValue[]
  bundleItems StoreBundleItem[]
  orderLines  StoreOrderLine[]

  @@index([productId, isActive, sortOrder])
  @@index([itemCode])
  @@map("store_product_variants")
}

model StoreProductVariantOptionValue {
  variantId     String @map("variant_id")
  optionValueId String @map("option_value_id")

  variant     StoreProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue StoreProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@index([optionValueId])
  @@map("store_product_variant_option_values")
}

model StoreBundle {
  id             String   @id @default(cuid())
  profileId      String   @map("profile_id")
  name           String
  slug           String
  summary        String?
  description    String?
  badge          String?
  accentColor    String?  @map("accent_color")
  price          Int
  compareAtPrice Int?     @map("compare_at_price")
  isFeatured     Boolean  @default(false) @map("is_featured")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  profile    ServerProfile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  items      StoreBundleItem[]
  orderLines StoreOrderLine[]

  @@unique([profileId, slug])
  @@index([profileId, isActive, isFeatured, sortOrder])
  @@map("store_bundles")
}

model StoreBundleItem {
  bundleId  String @map("bundle_id")
  variantId String @map("variant_id")
  quantity  Int    @default(1)
  sortOrder Int    @default(0) @map("sort_order")

  bundle  StoreBundle         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  variant StoreProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([bundleId, variantId])
  @@index([variantId])
  @@map("store_bundle_items")
}

model StoreProductRecommendation {
  sourceProductId String  @map("source_product_id")
  targetProductId String  @map("target_product_id")
  reason          String?
  sortOrder       Int     @default(0) @map("sort_order")

  sourceProduct StoreProduct @relation("StoreProductRecommendationSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct StoreProduct @relation("StoreProductRecommendationTarget", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@id([sourceProductId, targetProductId])
  @@index([targetProductId])
  @@map("store_product_recommendations")
}

model StoreOrder {
  id            String           @id @default(cuid())
  profileId     String           @map("profile_id")
  userId        String           @map("user_id")
  playerId      String?          @map("player_id")
  status        StoreOrderStatus @default(PROCESSING)
  subtotal      Int
  discountTotal Int              @default(0) @map("discount_total")
  total         Int
  notes         String?
  metadata      Json?
  deliveredAt   DateTime?        @map("delivered_at")
  failedAt      DateTime?        @map("failed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  profile ServerProfile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  player  ServerPlayer?    @relation(fields: [playerId], references: [id], onDelete: SetNull)
  lines   StoreOrderLine[]

  @@index([profileId, createdAt])
  @@index([userId, createdAt])
  @@index([playerId, createdAt])
  @@map("store_orders")
}

model StoreOrderLine {
  id                 String             @id @default(cuid())
  orderId            String             @map("order_id")
  kind               StoreOrderLineKind
  productId          String?            @map("product_id")
  variantId          String?            @map("variant_id")
  bundleId           String?            @map("bundle_id")
  title              String
  sku                String?
  itemCode           String?            @map("item_code")
  quantity           Int
  unitPrice          Int                @map("unit_price")
  compareAtUnitPrice Int?               @map("compare_at_unit_price")
  total              Int
  snapshot           Json?
  sortOrder          Int                @default(0) @map("sort_order")
  createdAt          DateTime           @default(now()) @map("created_at")

  order   StoreOrder           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product StoreProduct?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant StoreProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  bundle  StoreBundle?         @relation(fields: [bundleId], references: [id], onDelete: SetNull)

  @@index([orderId, sortOrder])
  @@index([productId])
  @@index([variantId])
  @@index([bundleId])
  @@map("store_order_lines")
}
