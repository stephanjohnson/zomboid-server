# =============================================================================
# Zomboid Server Manager — Environment Variables
# =============================================================================

# --- App ---
NODE_ENV=production
APP_PORT=3000
APP_SECRET=change-me-to-a-random-64-char-string
JWT_SECRET=change-me-to-a-random-64-char-string

# --- Database (PostgreSQL) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=zomboid
DB_USER=zomboid
DB_PASSWORD=zomboid
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=zomboid
RABBITMQ_PASSWORD=zomboid
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}

# --- Game Server ---
GAME_SERVER_CONTAINER_NAME=pzm-game-server
GAME_SERVER_NETWORK_NAME=zomboid-server_zomboid-net
GAME_SERVER_NETWORK_ALIAS=game-server
SERVERNAME=servertest
PZ_GAME_PORT=16261
PZ_DIRECT_PORT=16262
PZ_RCON_HOST=game-server
PZ_RCON_PORT=27015
PZ_RCON_PASSWORD=change-me

# --- Docker Proxy ---
DOCKER_PROXY_URL=http://docker-socket-proxy:2375

# --- Paths (inside containers) ---
PZ_DATA_PATH=/pzm-data
PZ_SERVER_PATH=/pzm-server
BACKUP_PATH=/backups
LUA_BRIDGE_PATH=/lua-bridge
GAME_SERVER_SERVER_FILES_MOUNT_SOURCE=pzm-server-files

# --- Admin (first-run seed) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=change-me

# --- Caddy ---
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
SITE_DOMAIN=localhost
